<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <!--
        Added the constraints for entity Comment.
    -->
    <changeSet id="20240303123230-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="post_commented_id"
                                 baseTableName="comment"
                                 constraintName="fk_comment__post_commented_id"
                                 referencedColumnNames="id"
                                 referencedTableName="post"/>

        <addForeignKeyConstraint baseColumnNames="user_commented_id"
                                 baseTableName="comment"
                                 constraintName="fk_comment__user_commented_id"
                                 referencedColumnNames="id"
                                 referencedTableName="user_profile"/>
    </changeSet>
</databaseChangeLog>

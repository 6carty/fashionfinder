<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <!--
        Added the constraints for entity Likes.
    -->
    <changeSet id="20240303123229-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="post_id"
                                 baseTableName="likes"
                                 constraintName="fk_likes__post_id"
                                 referencedColumnNames="id"
                                 referencedTableName="post"/>

        <addForeignKeyConstraint baseColumnNames="user_liked_id"
                                 baseTableName="likes"
                                 constraintName="fk_likes__user_liked_id"
                                 referencedColumnNames="id"
                                 referencedTableName="user_profile"/>
    </changeSet>
</databaseChangeLog>

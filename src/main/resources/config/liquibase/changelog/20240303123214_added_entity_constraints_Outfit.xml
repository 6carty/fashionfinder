<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <!--
        Added the constraints for entity Outfit.
    -->
    <changeSet id="20240303123214-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="weather_id"
                                 baseTableName="outfit"
                                 constraintName="fk_outfit__weather_id"
                                 referencedColumnNames="id"
                                 referencedTableName="weather"/>

        <addForeignKeyConstraint baseColumnNames="rating_id"
                                 baseTableName="outfit"
                                 constraintName="fk_outfit__rating_id"
                                 referencedColumnNames="id"
                                 referencedTableName="rating"/>

        <addForeignKeyConstraint baseColumnNames="event_id"
                                 baseTableName="outfit"
                                 constraintName="fk_outfit__event_id"
                                 referencedColumnNames="id"
                                 referencedTableName="event"/>

        <addForeignKeyConstraint baseColumnNames="creator_id"
                                 baseTableName="outfit"
                                 constraintName="fk_outfit__creator_id"
                                 referencedColumnNames="id"
                                 referencedTableName="user_profile"/>
    </changeSet>
</databaseChangeLog>
